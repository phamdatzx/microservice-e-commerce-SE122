##
# Copy to `.env` and adjust. Environment variables already set in the shell
# take precedence over this file.
##

PROJECT_NAME="AI Service"
API_V1_PREFIX="/api/ai"
VERSION="0.1.0"
DEBUG="false"

QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""
# Unified collection for product embeddings (RAG + content-based recommendations)
QDRANT_PRODUCT_DOC_COLLECTION="product_docs"
QDRANT_USER_COLLECTION_NAME="user_vectors"

RABBITMQ_URL="amqp://guest:guest@localhost:5672/"
PRODUCT_CREATED_QUEUE="product.created"
USER_VECTOR_QUEUE="user.vector.update"

# OpenAI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
OPENAI_TEMPERATURE=0
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# MongoDB — required for `user_vector_worker` (interaction history)
MONGO_URI="mongodb://localhost:27017"
MONGO_DB_NAME="ecommerce"
INTERACTION_COLLECTION_NAME="user_interactions"

# Newest N interactions per user used to compute the Qdrant user vector
USER_INTERACTION_HISTORY_LIMIT=100

# JSON map: action name -> weight when the message omits `score`
INTERACTION_ACTION_SCORES_JSON={"view":1,"click":2,"purchase":10,"add_to_cart":10}

# Fallback weight if `action` is not listed above (and `score` is omitted)
INTERACTION_DEFAULT_SCORE=1

# Downstream microservice base URLs (through Traefik gateway)
PRODUCT_SERVICE_URL="http://localhost:81"
ORDER_SERVICE_URL="http://localhost:81"
