##
# AI Service — copy to `.env` and fill in your values.
# Variables already set in the shell take precedence over this file.
##

# Service metadata
PROJECT_NAME="AI Service"
API_V1_PREFIX="/api/ai"
VERSION="0.1.0"
DEBUG="false"

# Qdrant
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""
QDRANT_USER_COLLECTION_NAME="user_vectors"
QDRANT_COLLECTION_NAME="products"
QDRANT_PRODUCT_DOC_COLLECTION="product_docs"

# RabbitMQ
RABBITMQ_URL="amqp://guest:guest@localhost:5672/"
PRODUCT_CREATED_QUEUE="product.created"
USER_VECTOR_QUEUE="user.interaction"

# MongoDB — required for user_vector_worker and cf_worker
MONGO_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=e-commerce"
MONGO_DB_NAME="ecommerce"
INTERACTION_COLLECTION_NAME="user_interactions"
USER_INTERACTION_HISTORY_LIMIT=100
INTERACTION_ACTION_SCORES_JSON={"view":1,"click":2,"purchase":10,"add_to_cart":10}
INTERACTION_DEFAULT_SCORE=1

# OpenAI
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"
OPENAI_TEMPERATURE=0
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# RAG retrieval settings
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.5

# Downstream microservice base URLs
# Local dev: use localhost with the service's direct port
# Docker Compose: use service names (see .env.compose)
PRODUCT_SERVICE_URL="http://localhost:8085"
ORDER_SERVICE_URL="http://localhost:8085"
